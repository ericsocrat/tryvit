{
  "name": "tryvit-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "INTEGRATION=1 vitest run rpc-contract",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "npx playwright test --project=smoke",
    "test:e2e:visual": "VISUAL_REGRESSION=true npx playwright test",
    "test:e2e:scanner": "npx playwright test authenticated-scanner",
    "quality:smoke": "QA_MODE_LEVEL=smoke npx playwright test tests/quality/ --reporter=html,list",
    "quality:full": "QA_MODE_LEVEL=full npx playwright test tests/quality/ --reporter=html,list",
    "lighthouse:mobile": "lhci autorun --config=lighthouserc.mobile.js",
    "lighthouse:desktop": "lhci autorun --config=lighthouserc.desktop.js",
    "lighthouse": "npm run lighthouse:mobile && npm run lighthouse:desktop",
    "optimize:svg": "svgo -r -f public/icons --config svgo.config.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.5.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.46.0",
    "@serwist/next": "^9.5.7",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.95.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/speed-insights": "^2.0.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "sonner": "^2.0.7",
    "tesseract.js": "^7.0.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "minimatch": ">=10.2.4",
    "@eslint/eslintrc": {
      "minimatch": "^3.1.5"
    },
    "serialize-javascript": ">=7.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.2",
    "axe-core": "^4.11.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  }
}
