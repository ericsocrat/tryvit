# EditorConfig — TryVit
# https://editorconfig.org
# Applies to all editors that support EditorConfig.
# VS Code: install editorconfig.editorconfig extension.

root = true

# ── Universal defaults ──────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ── SQL ─────────────────────────────────────────────────────────────────────
[*.sql]
indent_size = 2
max_line_length = 120

# ── Markdown — preserve trailing spaces (used for line breaks) ───────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ── PowerShell ───────────────────────────────────────────────────────────────
[*.{ps1,psm1,psd1}]
indent_size = 4
max_line_length = 120

# ── Python ───────────────────────────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 120

# ── TOML ─────────────────────────────────────────────────────────────────────
[*.toml]
indent_size = 2

# ── TypeScript / JavaScript ───────────────────────────────────────────────────
[*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}]
indent_size = 2
max_line_length = 100

# ── JSON / JSONC ─────────────────────────────────────────────────────────────
[*.{json,jsonc}]
indent_size = 2

# ── YAML ─────────────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2
max_line_length = 120

# ── Dockerfile ───────────────────────────────────────────────────────────────
[Dockerfile*]
indent_size = 4

# ── CSS / SCSS ───────────────────────────────────────────────────────────────
[*.{css,scss}]
indent_size = 2

# ── Shell scripts ────────────────────────────────────────────────────────────
[*.sh]
indent_size = 2
end_of_line = lf

# ── Config files (no line-length gate) ───────────────────────────────────────
[*.{properties,conf,cfg,ini}]
trim_trailing_whitespace = true
