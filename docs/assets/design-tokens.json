{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$version": "2.0.0",
  "$brand": "TryVit",
  "$description": "TryVit — Design tokens for brand identity, scoring, and UI surfaces. Source of truth: frontend/src/styles/globals.css + frontend/tailwind.config.ts",
  "brand": {
    "vitGreen": {
      "value": "#1DB954",
      "usage": "Primary CTA, score indicator (healthy), themeColor, TileColor",
      "wcag": {
        "onVitDark": "7.4:1 (AAA)"
      }
    },
    "vitDark": {
      "value": "#0A2E1A",
      "usage": "Logo wordmark, text on light, dark themeColor, app bg on dark",
      "wcag": {
        "onVitLight": "14.9:1 (AAA)"
      }
    },
    "vitLight": {
      "value": "#F0FAF4",
      "usage": "App background, card fill, light surface",
      "wcag": {
        "note": "Background — not used for text on its own"
      }
    },
    "vitAccent": {
      "value": "#00E676",
      "usage": "Glow, highlight, active state — NOT for text on white (4.4:1 borderline)",
      "wcag": {
        "onVitDark": "8.2:1 (AAA)"
      }
    },
    "vitNeutral": {
      "value": "#6B7280",
      "usage": "Secondary text, borders, icon strokes",
      "wcag": {
        "onWhite": "4.6:1 (AA)"
      }
    },
    "vitWarning": {
      "value": "#F59E0B",
      "usage": "Moderate risk score band (41–60)",
      "wcag": {
        "onWhite": "2.8:1 (decorative only)"
      }
    },
    "vitDanger": {
      "value": "#EF4444",
      "usage": "High / very-high risk score band (61–100)",
      "wcag": {
        "onWhite": "3.7:1 (decorative only)"
      }
    }
  },
  "colorsDark": {
    "surface100": {
      "value": "#0A2E1A",
      "usage": "Primary dark background"
    },
    "surface200": {
      "value": "#0F3D22",
      "usage": "Raised card on dark bg"
    },
    "surface300": {
      "value": "#1A5C32",
      "usage": "Elevated panel on dark bg"
    },
    "inkPrimary": {
      "value": "#F0FAF4",
      "usage": "Primary text on dark surfaces"
    },
    "inkSecondary": {
      "value": "#9DCFB0",
      "usage": "Secondary / muted text on dark"
    },
    "accent": {
      "value": "#00E676",
      "usage": "Glow / active state on dark"
    },
    "accentOnDark": {
      "value": "#1DB954",
      "usage": "Primary brand green on dark"
    },
    "danger": {
      "value": "#FF6B6B",
      "usage": "Error state on dark surface"
    },
    "warning": {
      "value": "#FFD166",
      "usage": "Warning state on dark surface"
    }
  },
  "scoring": {
    "green": {
      "value": "#22c55e",
      "range": "1–20",
      "label": "Low Risk",
      "textValue": "#15803d",
      "textWcag": "5.1:1 (AA)"
    },
    "yellow": {
      "value": "#eab308",
      "range": "21–40",
      "label": "Moderate",
      "textValue": "#854d0e",
      "textWcag": "5.9:1 (AA)"
    },
    "orange": {
      "value": "#f97316",
      "range": "41–60",
      "label": "Elevated",
      "textValue": "#c2410c",
      "textWcag": "5.2:1 (AA)"
    },
    "red": {
      "value": "#ef4444",
      "range": "61–80",
      "label": "High Risk",
      "textValue": "#b91c1c",
      "textWcag": "5.9:1 (AA)"
    },
    "darkred": {
      "value": "#991b1b",
      "range": "81–100",
      "label": "Very High Risk",
      "textValue": "#991b1b",
      "textWcag": "8.3:1 (AAA)"
    }
  },
  "nutriScore": {
    "A": {
      "value": "#038141",
      "label": "Best nutritional quality"
    },
    "B": {
      "value": "#85bb2f",
      "label": "Good nutritional quality"
    },
    "C": {
      "value": "#fecb02",
      "label": "Average nutritional quality"
    },
    "D": {
      "value": "#ee8100",
      "label": "Poor nutritional quality"
    },
    "E": {
      "value": "#e63e11",
      "label": "Worst nutritional quality"
    }
  },
  "nova": {
    "1": {
      "value": "#22c55e",
      "label": "Unprocessed or minimally processed"
    },
    "2": {
      "value": "#84cc16",
      "label": "Processed culinary ingredients"
    },
    "3": {
      "value": "#f59e0b",
      "label": "Processed foods"
    },
    "4": {
      "value": "#ef4444",
      "label": "Ultra-processed products"
    }
  },
  "semantic": {
    "success": {
      "value": "#22c55e",
      "usage": "Positive outcomes, confirmations"
    },
    "warning": {
      "value": "#f59e0b",
      "usage": "Caution states, approaching limits"
    },
    "error": {
      "value": "#ef4444",
      "usage": "Errors, destructive actions, alerts"
    },
    "info": {
      "value": "#3b82f6",
      "usage": "Informational messages, neutral highlights"
    }
  },
  "surfaces": {
    "light": {
      "default": {
        "value": "#ffffff"
      },
      "subtle": {
        "value": "#f9fafb",
        "note": "gray-50"
      },
      "muted": {
        "value": "#f3f4f6",
        "note": "gray-100"
      },
      "overlay": {
        "value": "rgba(0, 0, 0, 0.5)"
      }
    },
    "dark": {
      "default": {
        "value": "#111827",
        "note": "gray-900"
      },
      "subtle": {
        "value": "#1f2937",
        "note": "gray-800"
      },
      "muted": {
        "value": "#374151",
        "note": "gray-700"
      },
      "overlay": {
        "value": "rgba(0, 0, 0, 0.7)"
      }
    }
  },
  "neutral": {
    "light": {
      "50": "#f8fafc",
      "200": "#e2e8f0",
      "400": "#94a3b8",
      "600": "#475569",
      "900": "#0f172a"
    },
    "dark": {
      "50": "#0f172a",
      "200": "#334155",
      "400": "#94a3b8",
      "600": "#cbd5e1",
      "900": "#f8fafc"
    }
  },
  "text": {
    "light": {
      "primary": {
        "value": "#111827",
        "wcag": "17.4:1 on white"
      },
      "secondary": {
        "value": "#4b5563",
        "wcag": "7.1:1 on white (AA)"
      },
      "muted": {
        "value": "#6b7280",
        "wcag": "4.6:1 on white (AA)"
      },
      "inverse": {
        "value": "#ffffff"
      }
    },
    "dark": {
      "primary": {
        "value": "#f9fafb"
      },
      "secondary": {
        "value": "#d1d5db"
      },
      "muted": {
        "value": "#9ca3af"
      },
      "inverse": {
        "value": "#111827"
      }
    }
  },
  "confidence": {
    "high": {
      "value": "#22c55e",
      "label": "High data confidence"
    },
    "medium": {
      "value": "#f59e0b",
      "label": "Medium data confidence"
    },
    "low": {
      "value": "#ef4444",
      "label": "Low data confidence"
    }
  },
  "allergen": {
    "present": {
      "value": "#ef4444",
      "label": "Contains allergen"
    },
    "traces": {
      "value": "#f59e0b",
      "label": "May contain traces"
    },
    "free": {
      "value": "#22c55e",
      "label": "Free from allergen"
    }
  },
  "border": {
    "default": {
      "value": "#e5e7eb",
      "note": "gray-200"
    },
    "strong": {
      "value": "#d1d5db",
      "note": "gray-300"
    }
  },
  "typography": {
    "fontFamily": {
      "display": "\"Inter\", \"SF Pro Display\", -apple-system, sans-serif",
      "body": "\"Inter\", -apple-system, BlinkMacSystemFont, sans-serif",
      "mono": "\"JetBrains Mono\", \"Fira Code\", monospace"
    },
    "typeScale": {
      "displayXL": {
        "size": "48px",
        "weight": 800,
        "tracking": "-0.03em",
        "leading": 1.1
      },
      "displayL": {
        "size": "36px",
        "weight": 700,
        "tracking": "-0.025em",
        "leading": 1.15
      },
      "heading": {
        "size": "24px",
        "weight": 600,
        "tracking": "-0.01em",
        "leading": 1.3
      },
      "body": {
        "size": "16px",
        "weight": 400,
        "tracking": "0",
        "leading": 1.6
      },
      "caption": {
        "size": "12px",
        "weight": 500,
        "tracking": "0.01em",
        "leading": 1.5
      },
      "label": {
        "size": "11px",
        "weight": 700,
        "tracking": "0.06em",
        "leading": 1.2
      }
    },
    "wordmark": {
      "fontFamily": "\"Inter\", sans-serif",
      "fontWeight": 800,
      "letterSpacing": "-0.03em",
      "tryColor": "#0A2E1A",
      "vitColor": "#1DB954",
      "note": "Render 'Try' in vitDark (#0A2E1A), 'Vit' in vitGreen (#1DB954)"
    }
  },
  "spacing": {
    "4": "4px",
    "8": "8px",
    "12": "12px",
    "16": "16px",
    "20": "20px",
    "24": "24px",
    "32": "32px",
    "48": "48px",
    "64": "64px",
    "80": "80px",
    "96": "96px"
  },
  "radius": {
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "2xl": "24px",
    "full": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,0.08)",
    "md": "0 4px 12px rgba(0,0,0,0.10)",
    "lg": "0 8px 24px rgba(0,0,0,0.12)",
    "card": "0 2px 8px rgba(10,46,26,0.08)"
  },
  "motion": {
    "fast": "120ms ease-out",
    "base": "200ms ease-in-out",
    "slow": "360ms ease-in-out",
    "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
  }
}
